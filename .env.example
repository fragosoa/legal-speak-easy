# Required
OPENAI_API_KEY=sk-...

# AI model config
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# App config
APP_ENV=development
MAX_FILE_SIZE_MB=10
CONTRACT_TEXT_MAX_CHARS=80000

# Q&A feature — used to sign context tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
